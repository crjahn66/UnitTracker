{
  "expo": {
    "name": "UnitTracker",
    "slug": "unit-tracker",
    "version": "1.5.24",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "package": "com.redgroup.unittracker",
      "permissions": ["REQUEST_INSTALL_PACKAGES", "CAMERA"]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow UnitTracker to use the camera to attach a photo when logging an issue."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/icon.png",
      "bundler": "metro"
    }
  }
}
